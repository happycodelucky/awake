xcuserdata/
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.xccheckout
*.xcscmblueprint
*.xcuserstate
build/
Awake.xcodeproj/xcuserdata/
Awake.xcodeproj/project.xcworkspace/xcuserdata/

